<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.learning.emsmybatisliquibase.dao.NotificationDao">
    <resultMap id="notificationMap" type="com.learning.emsmybatisliquibase.entity.Notification">
        <id property="uuid" column="uuid" jdbcType="VARCHAR" javaType="java.util.UUID"
        typeHandler="com.learning.emsmybatisliquibase.handler.UuidTypeHandler"/>
        <result property="employeeUuid" column="employee_uuid" jdbcType="VARCHAR" javaType="java.util.UUID"
                typeHandler="com.learning.emsmybatisliquibase.handler.UuidTypeHandler"/>
        <result property="title" column="title"/>
        <result property="message" column="message"/>
        <result property="link" column="link"/>
        <result property="status" column="status"/>
        <result property="createdTime" column="created_time"/>
        <result property="updatedTime" column="updated_time"/>
    </resultMap>

    <select id="count" resultType="long">
        SELECT count(*)
        FROM notification
        <trim prefix="WHERE" prefixOverrides="AND|OR" suffixOverrides="AND|OR">
            <if test="request != null">
                <include refid="applyFilter"/>
            </if>
        </trim>
    </select>

    <select id="get" resultMap="notificationMap">
        SELECT *
        FROM notification
        <trim prefix="WHERE" prefixOverrides="AND|OR" suffixOverrides="AND|OR">
            <if test="request != null">
                <include refid="applyFilter"/>
            </if>
        </trim>
    </select>

    <select id="getCount" resultType="map">
        SELECT status, count(*) AS count
        FROM notification
        WHERE employee_uuid = #{employeeUuid}
        GROUP BY status
    </select>

    <insert id="save" flushCache="true">
        INSERT INTO notification (uuid, employee_uuid, title, message, link, status, created_time, updated_time)
        VALUES (#{notification.uuid}, #{notification.employeeUuid}, #{notification.title}, #{notification.message},
                #{notification.link}, #{notification.status}, #{notification.createdTime}, #{notification.updatedTime})
    </insert>

    <update id="update" flushCache="true">
        UPDATE notification
        SET status       = #{newStatus},
            updated_time = #{updatedTime}
       <trim prefix="WHERE" prefixOverrides="AND|OR" suffixOverrides="AND|OR">
           <if test="request.properties != null">
               <include refid="applyFilter"/>
           </if>
       </trim>
    </update>

    <delete id="delete" flushCache="true">
        DELETE from notification
        <trim prefix="WHERE" prefixOverrides="AND|OR" suffixOverrides="AND|OR">
            <if test="request.properties != null">
                <include refid="applyFilter"/>
            </if>
        </trim>
    </delete>

    <sql id="applyFilter">
        <if test="request.properties.uuid != null">
            AND uuid = #{request.properties.uuid}
        </if>
        <if test="request.properties.sortBy != null">
            ORDER BY ${request.properties.sortBy} ${request.properties.sortOrder}
            LIMIT #{request.properties.size} OFFSET #{request.properties.offSet}
        </if>
        <if test="request.properties.employeeUuid != null">
            AND employee_uuid = #{request.properties.employeeUuid}
        </if>
        <if test="request.properties.statuses != null">
            AND status IN
            <foreach collection="request.properties.statuses" item="status" open="(" separator="," close=")">
                #{status}
            </foreach>
        </if>
    </sql>
</mapper>