<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.learning.emsmybatisliquibase.dao.AttendanceDao">
    <resultMap id="attendanceStructure" type="com.learning.emsmybatisliquibase.entity.Attendance">
        <id property="uuid" column="uuid" jdbcType="VARCHAR" javaType="java.util.UUID"
            typeHandler="com.learning.emsmybatisliquibase.handler.UuidTypeHandler"/>
        <result property="employeeUuid" column="employee_uuid" jdbcType="VARCHAR" javaType="java.util.UUID"
                typeHandler="com.learning.emsmybatisliquibase.handler.UuidTypeHandler"/>
        <result property="workMode" column="work_mode"/>
        <result property="type" column="type"/>
        <result property="status" column="status"/>
        <result property="date" column="date"/>
        <result property="createdTime" column="created_time"/>
        <result property="updatedTime" column="updated_time"/>
    </resultMap>

    <insert id="insert" flushCache="true">
        insert into attendance (uuid, employee_uuid, work_mode, type, status, date, created_time, updated_time)
        VALUES (#{attendance.uuid}, #{attendance.employeeUuid}, #{attendance.workMode}, #{attendance.type},
                #{attendance.status}, #{attendance.date}, #{attendance.createdTime}, #{attendance.updatedTime})
    </insert>

    <update id="update" flushCache="true">
        update attendance
        set employee_uuid = #{attendance.employeeUuid},
            work_mode     = #{attendance.workMode},
            type          = #{attendance.type},
            status        = #{attendance.status},
            date          = #{attendance.date},
            updated_time  = #{attendance.updatedTime}
        where uuid = #{attendance.uuid}
    </update>

    <select id="getById" resultMap="attendanceStructure">
        select *
        from attendance
        where uuid = #{uuid}
    </select>

    <select id="getByEmployeeUuid" resultMap="attendanceStructure">
        select *
        from attendance a
        where a.employee_uuid = #{employeeUuid}
        <trim prefix="AND" prefixOverrides="AND|OR" suffixOverrides="AND|OR">
            <include refid="applyFilters"/>
        </trim>
    </select>
    <select id="getTimesheet" resultType="java.lang.Integer">
        select EXTRACT(DAY FROM a.date)
        from employee e
        join attendance a on a.employee_uuid = e.uuid
        where a.employee_uuid = #{employeeUuid}
        <trim prefix="AND" prefixOverrides="AND|OR" suffixOverrides="AND|OR">
            <include refid="applyFilters"/>
        </trim>

    </select>

    <delete id="delete" flushCache="true">
        delete
        from attendance
        where uuid = #{uuid}
    </delete>

    <sql id="applyFilters">
        <if test="year != null">
            and EXTRACT(YEAR FROM a.date) = #{year}
        </if>
        <if test="month != null">
            and EXTRACT(MONTH FROM a.date) = #{month}
        </if>
    </sql>

    <resultMap id="attendanceGroupMap" type="com.learning.emsmybatisliquibase.dto.AttendanceGroupDto">
        <id property="status" column="status"/>
        <collection property="days" ofType="java.lang.Integer" notNullColumn="day">
            <result column="day"/>
        </collection>
    </resultMap>

    <select id="getGroupedAttendance" resultMap="attendanceGroupMap">
        select s.id as status, CAST(EXTRACT(DAY FROM a.date) AS INTEGER) as day
        from attendance_status s
            left join attendance a
        on a.status = s.id
            and a.employee_uuid = #{employeeUuid}
            and EXTRACT (YEAR FROM a.date) = #{year}
            and EXTRACT (MONTH FROM a.date) = #{month}
        order by s.id, day
    </select>

    <resultMap id="employeeAttendanceMap" type="com.learning.emsmybatisliquibase.dto.EmployeeAttendanceDto">
        <id property="employeeUuid" column="uuid" jdbcType="VARCHAR" javaType="java.util.UUID"
            typeHandler="com.learning.emsmybatisliquibase.handler.UuidTypeHandler"/>
        <result property="firstName" column="first_name"/>
        <result property="lastName" column="last_name"/>
        <result property="attendanceUuid" column="attendanceUuid" jdbcType="VARCHAR" javaType="java.util.UUID"
                typeHandler="com.learning.emsmybatisliquibase.handler.UuidTypeHandler"/>
        <result property="workMode" column="work_mode"/>
        <result property="type" column="type"/>
        <result property="status" column="status"/>
        <result property="date" column="date"/>
    </resultMap>
    <select id="getByManagerUuid" resultMap="employeeAttendanceMap">
        select e.uuid,
        e.first_name,
        e.last_name,
        a.uuid as attendanceUuid,
        a.work_mode,
        a.type,
        a.status,
        a.date
        from employee e
        join attendance a on a.employee_uuid = e.uuid
        where e.manager_uuid = #{managerUuid}
        <trim prefix="AND" prefixOverrides="AND" suffixOverrides="AND">
            <include refid="applyFilters"/>
        </trim>
    </select>
</mapper>
