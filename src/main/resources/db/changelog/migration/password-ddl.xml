<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.2.xsd">
    <changeSet id="1" author="rvenkata">
        <createTable tableName="password">
            <column name="uuid" type="${uuid_type}">
                <constraints nullable="false" primaryKey="true" primaryKeyName="password_pk"/>
            </column>
            <column name="employee_uuid" type="${uuid_type}">
                <constraints nullable="false"/>
            </column>
            <column name="password" type="VARCHAR">
                <constraints nullable="false"/>
            </column>
            <column name="no_of_incorrect_entries" type="number" defaultValueNumeric="0">
                <constraints nullable="true"/>
            </column>
            <column name="status" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="created_time" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_time" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="password_status">
            <column name="id" type="INTEGER">
                <constraints nullable="false" primaryKey="true" primaryKeyName="password_status_pk"/>
            </column>
            <column name="name" type="VARCHAR">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addForeignKeyConstraint baseTableName="password" baseColumnNames="employee_uuid" constraintName="employee_fk"
                                 deferrable="false" initiallyDeferred="false"
                                 onDelete="CASCADE" onUpdate="CASCADE"
                                 referencedTableName="employee" referencedColumnNames="uuid"/>
        <addForeignKeyConstraint baseTableName="password" baseColumnNames="status" constraintName="status_fk"
                                 deferrable="false" initiallyDeferred="false"
                                 onDelete="CASCADE" onUpdate="CASCADE"
                                 referencedTableName="password_status" referencedColumnNames="id"/>
        <insert tableName="password_status">
            <column name="id" value="1"/>
            <column name="name" value="ACTIVE"/>
        </insert>
        <insert tableName="password_status">
            <column name="id" value="2"/>
            <column name="name" value="EXPIRED"/>
        </insert>
        <insert tableName="password_status">
            <column name="id" value="3"/>
            <column name="name" value="LOCKED"/>
        </insert>
    </changeSet>
</databaseChangeLog>