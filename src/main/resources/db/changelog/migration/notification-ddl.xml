<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">
    <changeSet id="1" author="Venkata Krishna Repalle">
        <createTable tableName="notification">
            <column name="uuid" type="${uuid_type}">
                <constraints nullable="false" primaryKeyName="notification_pk" primaryKey="true"/>
            </column>
            <column name="employee_uuid" type="${uuid_type}">
                <constraints nullable="false"/>
            </column>
            <column name="title" type="VARCHAR">
                <constraints nullable="false"/>
            </column>
            <column name="message" type="VARCHAR">
                <constraints nullable="false"/>
            </column>
            <column name="link" type="VARCHAR"/>
            <column name="status" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="created_time" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_time" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="notification_status">
            <column name="id" type="INTEGER">
                <constraints nullable="false" primaryKey="true" primaryKeyName="notification_status_pk"/>
            </column>
            <column name="name" type="VARCHAR">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <insert tableName="notification_status">
            <column name="id" value="1"/>
            <column name="name" value="READ"/>
        </insert>
        <insert tableName="notification_status">
            <column name="id" value="2"/>
            <column name="name" value="UNREAD"/>
        </insert>

        <addForeignKeyConstraint baseTableName="notification" baseColumnNames="employee_uuid"
                                 constraintName="notification_employee_fk" initiallyDeferred="false"
                                 deferrable="false" onDelete="CASCADE" onUpdate="CASCADE"
                                 referencedTableName="employee" referencedColumnNames="uuid"/>
        <addForeignKeyConstraint baseTableName="notification" baseColumnNames="status"
                                 constraintName="notification_status_fk" initiallyDeferred="false"
                                 deferrable="false" onDelete="CASCADE" onUpdate="CASCADE"
                                 referencedTableName="notification_status" referencedColumnNames="id"/>
    </changeSet>
</databaseChangeLog>