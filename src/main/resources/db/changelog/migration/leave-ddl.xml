<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.2.xsd">
    <changeSet id="1" author="rvenkata">
        <createTable tableName="leave">
            <column name="uuid" type="${uuid_type}">
                <constraints nullable="false" primaryKey="true" primaryKeyName="leave_pk"/>
            </column>
            <column name="employee_uuid" type="${uuid_type}">
                <constraints nullable="false"/>
            </column>
            <column name="date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="type" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="reason" type="VARCHAR">
                <constraints nullable="false"/>
            </column>
            <column name="comments" type="VARCHAR">
                <constraints nullable="true"/>
            </column>
            <column name="created_time" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_time" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="leave_status">
            <column name="id" type="INTEGER">
                <constraints nullable="false" primaryKey="true" primaryKeyName="leave_status_id_pk"/>
            </column>
            <column name="name" type="VARCHAR">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <insert tableName="leave_status">
            <column name="id" value="1"/>
            <column name="name" value="WAITING_FOR_APPROVAL"/>
        </insert>
        <insert tableName="leave_status">
            <column name="id" value="2"/>
            <column name="name" value="APPROVED"/>
        </insert>
        <insert tableName="leave_status">
            <column name="id" value="3"/>
            <column name="name" value="DECLINED"/>
        </insert>
        <insert tableName="leave_status">
            <column name="id" value="4"/>
            <column name="name" value="CANCELLED"/>
        </insert>

        <addForeignKeyConstraint baseTableName="leave" baseColumnNames="employee_uuid"
                                 constraintName="employee_uuid_fk" initiallyDeferred="false"
                                 deferrable="false" onUpdate="CASCADE" onDelete="CASCADE"
                                 referencedTableName="employee" referencedColumnNames="uuid"/>
        <addForeignKeyConstraint baseTableName="leave" baseColumnNames="status"
                                 constraintName="leave_status_fk" initiallyDeferred="false"
                                 deferrable="false" onUpdate="CASCADE" onDelete="CASCADE"
                                 referencedTableName="leave_status" referencedColumnNames="id"/>
        <addForeignKeyConstraint baseTableName="leave" baseColumnNames="type"
                                 constraintName="leave_type_fk" initiallyDeferred="false"
                                 deferrable="false" onUpdate="CASCADE" onDelete="CASCADE"
                                 referencedTableName="attendance_type" referencedColumnNames="id"/>
    </changeSet>
</databaseChangeLog>