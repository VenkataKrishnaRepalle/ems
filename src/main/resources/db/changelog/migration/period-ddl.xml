<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.2.xsd">
    <changeSet id="1" author="rvenkata">
        <createTable tableName="period">
            <column name="uuid" type="${uuid_type}">
                <constraints nullable="false" primaryKey="true" primaryKeyName="period_uuid_pk"/>
            </column>
            <column name="name" type="VARCHAR">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="VARCHAR">
                <constraints nullable="false"/>
            </column>
            <column name="start_time" type="timestamp">
                <constraints nullable="false"/>
            </column>
            <column name="end_time" type="timestamp">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="${uuid_type}">
                <constraints nullable="false"/>
            </column>
            <column name="created_time" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_time" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <createTable tableName="period_status">
            <column name="id" type="INTEGER">
                <constraints nullable="false" primaryKey="true" primaryKeyName="period_status_id_pk"/>
            </column>
            <column name="name" type="VARCHAR">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseTableName="period" baseColumnNames="status"
                                 initiallyDeferred="false" deferrable="false"
                                 onUpdate="CASCADE" onDelete="CASCADE" constraintName="period_status_id_fk"
                                 referencedTableName="period_status" referencedColumnNames="id"/>

        <insert tableName="period_status">
            <column name="id" value="1"/>
            <column name="name" value="DRAFT"/>
        </insert>
        <insert tableName="period_status">
            <column name="id" value="2"/>
            <column name="name" value="INACTIVE"/>
        </insert>
        <insert tableName="period_status">
            <column name="id" value="3"/>
            <column name="name" value="SCHEDULED"/>
        </insert>
        <insert tableName="period_status">
            <column name="id" value="4"/>
            <column name="name" value="STARTED"/>
        </insert>
        <insert tableName="period_status">
            <column name="id" value="5"/>
            <column name="name" value="FAILED"/>
        </insert>
        <insert tableName="period_status">
            <column name="id" value="6"/>
            <column name="name" value="COMPLETED"/>
        </insert>
    </changeSet>

    <changeSet id="2" author="rvenkata">
        <createTable tableName="employee_period">
            <column name="uuid" type="${uuid_type}">
                <constraints nullable="false" primaryKey="true" primaryKeyName="employee_period_uuid_pk"/>
            </column>
            <column name="employee_uuid" type="${uuid_type}">
                <constraints nullable="false"/>
            </column>
            <column name="period_uuid" type="${uuid_type}">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="created_time" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_time" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseTableName="employee_period" baseColumnNames="employee_uuid"
                                 constraintName="employee_uuid_fk" deferrable="false"
                                 initiallyDeferred="false" onUpdate="CASCADE" onDelete="CASCADE"
                                 referencedTableName="employee" referencedColumnNames="uuid"/>

        <addForeignKeyConstraint baseTableName="employee_period" baseColumnNames="period_uuid"
                                 constraintName="period_uuid_fk" deferrable="false"
                                 initiallyDeferred="false" onUpdate="CASCADE" onDelete="CASCADE"
                                 referencedTableName="period" referencedColumnNames="uuid"/>

        <addForeignKeyConstraint baseTableName="employee_period" baseColumnNames="status"
                                 initiallyDeferred="false" deferrable="false"
                                 onUpdate="CASCADE" onDelete="CASCADE" constraintName="period_status_id_fk"
                                 referencedTableName="period_status" referencedColumnNames="id"/>
    </changeSet>

    <changeSet id="3" author="rvenkata">
        <createTable tableName="review_timeline">
            <column name="uuid" type="${uuid_type}">
                <constraints nullable="false" primaryKey="true" primaryKeyName="review_timeline_uuid_pk"/>
            </column>
            <column name="employee_period_uuid" type="${uuid_type}">
                <constraints nullable="false"/>
            </column>
            <column name="type" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="start_time" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="overdue_time" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="lock_time" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="end_time" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="summary_status" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="created_time" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_time" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="review_type">
            <column name="id" type="INTEGER">
                <constraints nullable="false" primaryKey="true" primaryKeyName="review_type_id_pk"/>
            </column>
            <column name="name" type="VARCHAR">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseTableName="review_timeline" baseColumnNames="employee_period_uuid"
                                 constraintName="employee_period_uuid_fk" deferrable="false"
                                 initiallyDeferred="false" onDelete="CASCADE" onUpdate="CASCADE"
                                 referencedTableName="employee_period" referencedColumnNames="uuid"/>

        <addForeignKeyConstraint baseTableName="review_timeline" baseColumnNames="type"
                                 constraintName="review_type_id_fk" deferrable="false"
                                 initiallyDeferred="false" onDelete="CASCADE" onUpdate="CASCADE"
                                 referencedTableName="review_type" referencedColumnNames="id"/>

        <insert tableName="review_type">
            <column name="id" value="1"/>
            <column name="name" value="Q1"/>
        </insert>
        <insert tableName="review_type">
            <column name="id" value="2"/>
            <column name="name" value="Q2"/>
        </insert>
        <insert tableName="review_type">
            <column name="id" value="3"/>
            <column name="name" value="Q3"/>
        </insert>
        <insert tableName="review_type">
            <column name="id" value="4"/>
            <column name="name" value="Q4"/>
        </insert>

        <createTable tableName="review_timeline_status">
            <column name="id" type="INTEGER">
                <constraints nullable="false" primaryKey="true" primaryKeyName="review_timeline_status_id_pk"/>
            </column>
            <column name="name" type="VARCHAR">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseTableName="review_timeline" baseColumnNames="status"
                                 constraintName="review_timeline_status_id_fk" deferrable="false"
                                 initiallyDeferred="false" onDelete="CASCADE" onUpdate="CASCADE"
                                 referencedTableName="review_timeline_status" referencedColumnNames="id"/>

        <insert tableName="review_timeline_status">
            <column name="id" value="1"/>
            <column name="name" value="NOT_STARTED"/>
        </insert>
        <insert tableName="review_timeline_status">
            <column name="id" value="2"/>
            <column name="name" value="SCHEDULED"/>
        </insert>
        <insert tableName="review_timeline_status">
            <column name="id" value="3"/>
            <column name="name" value="STARTED"/>
        </insert>
        <insert tableName="review_timeline_status">
            <column name="id" value="4"/>
            <column name="name" value="OVERDUE"/>
        </insert>
        <insert tableName="review_timeline_status">
            <column name="id" value="5"/>
            <column name="name" value="LOCKED"/>
        </insert>
        <insert tableName="review_timeline_status">
            <column name="id" value="6"/>
            <column name="name" value="COMPLETED"/>
        </insert>

        <createTable tableName="review_status">
            <column name="id" type="INTEGER">
                <constraints nullable="false" primaryKey="true" primaryKeyName="review_status_id_pk"/>
            </column>
            <column name="name" type="VARCHAR">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseTableName="review_timeline" baseColumnNames="summary_status"
                                 constraintName="review_timeline_summary_status_id_fk" deferrable="false"
                                 initiallyDeferred="false" onDelete="CASCADE" onUpdate="CASCADE"
                                 referencedTableName="review_status" referencedColumnNames="id"/>

        <insert tableName="review_status">
            <column name="id" value="1"/>
            <column name="name" value="NOT_SUBMITTED"/>
        </insert>
        <insert tableName="review_status">
            <column name="id" value="2"/>
            <column name="name" value="DRAFT"/>
        </insert>
        <insert tableName="review_status">
            <column name="id" value="3"/>
            <column name="name" value="WAITING_FOR_APPROVAL"/>
        </insert>
        <insert tableName="review_status">
            <column name="id" value="4"/>
            <column name="name" value="APPROVED"/>
        </insert>
        <insert tableName="review_status">
            <column name="id" value="5"/>
            <column name="name" value="DECLINED"/>
        </insert>
        <insert tableName="review_status">
            <column name="id" value="6"/>
            <column name="name" value="COMPLETED"/>
        </insert>
    </changeSet>

    <changeSet id="4" author="rvenkata">
        <createTable tableName="review">
            <column name="uuid" type="${uuid_type}">
                <constraints nullable="false" primaryKey="true" primaryKeyName="review_uuid_pk"/>
            </column>
            <column name="review_timeline_uuid" type="${uuid_type}">
                <constraints nullable="false"/>
            </column>
            <column name="type" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="what_went_well" type="VARCHAR">
                <constraints nullable="false"/>
            </column>
            <column name="what_done_better" type="varchar">
                <constraints nullable="false"/>
            </column>
            <column name="way_forward" type="VARCHAR">
                <constraints nullable="false"/>
            </column>
            <column name="overall_comments" type="VARCHAR">
                <constraints nullable="true"/>
            </column>
            <column name="manager_what_went_well" type="VARCHAR">
                <constraints nullable="true"/>
            </column>
            <column name="manager_what_done_better" type="VARCHAR">
                <constraints nullable="true"/>
            </column>
            <column name="manager_way_forward" type="VARCHAR">
                <constraints nullable="true"/>
            </column>
            <column name="manager_overall_comments" type="VARCHAR">
                <constraints nullable="true"/>
            </column>
            <column name="rating" type="INTEGER">
                <constraints nullable="true"/>
            </column>
            <column name="status" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="created_time" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_time" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseTableName="review" baseColumnNames="review_timeline_uuid"
                                 constraintName="review_timeline_uuid_fk" initiallyDeferred="false"
                                 deferrable="false" onUpdate="CASCADE" onDelete="CASCADE"
                                 referencedTableName="review_timeline" referencedColumnNames="uuid"/>
        <addForeignKeyConstraint baseTableName="review" baseColumnNames="status"
                                 constraintName="review_status_id_fk" deferrable="false"
                                 initiallyDeferred="false" onDelete="CASCADE" onUpdate="CASCADE"
                                 referencedTableName="review_status" referencedColumnNames="id"/>
        <addForeignKeyConstraint baseTableName="review" baseColumnNames="type"
                                 constraintName="review_type_id_fk" deferrable="false"
                                 initiallyDeferred="false" onDelete="CASCADE" onUpdate="CASCADE"
                                 referencedTableName="review_type" referencedColumnNames="id"/>

        <createTable tableName="review_rating">
            <column name="id" type="INTEGER">
                <constraints nullable="false" primaryKey="true" primaryKeyName="review_rating_pk"/>
            </column>
            <column name="name" type="VARCHAR">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addForeignKeyConstraint baseTableName="review" baseColumnNames="rating"
                                 constraintName="review_rating_id_fk" deferrable="false"
                                 initiallyDeferred="false" onDelete="CASCADE" onUpdate="CASCADE"
                                 referencedTableName="review_rating" referencedColumnNames="id"/>
        <insert tableName="review_rating">
            <column name="id" value="1"/>
            <column name="name" value="NEW_TO_BUSINESS"/>
        </insert>
        <insert tableName="review_rating">
            <column name="id" value="2"/>
            <column name="name" value="BELOW_EXPECTED"/>
        </insert>
        <insert tableName="review_rating">
            <column name="id" value="3"/>
            <column name="name" value="EXPECTED"/>
        </insert>
        <insert tableName="review_rating">
            <column name="id" value="4"/>
            <column name="name" value="BROADLY_IN_LINE"/>
        </insert>
        <insert tableName="review_rating">
            <column name="id" value="5"/>
            <column name="name" value="GREAT"/>
        </insert>
        <insert tableName="review_rating">
            <column name="id" value="6"/>
            <column name="name" value="OUTSTANDING"/>
        </insert>
    </changeSet>
</databaseChangeLog>